{
  "name": "tsunonton",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev:css",
    "build": "npm run build:css:all",
    "build:js": "esbuild static/js/app.js --bundle --minify --outfile=static/js/app.min.js",
    "obfuscate": "esbuild static/js/app.js --bundle --minify --minify-whitespace --minify-identifiers --minify-syntax --tree-shaking=true --drop:console --drop:debugger --legal-comments=none --format=esm --target=es2020 --outfile=static/js/app.min.js",
    "optimize": "npm run build:css:all && npm run build:js",
    "build:css:cookies": "tailwindcss -i ./src/css/pages/cookies.input.css -o ./static/css/cookies.min.css --content \"./cookies.html,./static/js/**/*.js\" --minify",
    "build:css:index": "tailwindcss -i ./src/css/pages/index.input.css -o ./static/css/index.min.css --content \"./index.html,./static/js/**/*.js\" --minify",
    "build:css:knowledge": "tailwindcss -i ./src/css/pages/knowledge.input.css -o ./static/css/knowledge.min.css --content \"./knowledge.html,./static/js/**/*.js\" --minify",
    "build:css:privacy": "tailwindcss -i ./src/css/pages/privacy.input.css -o ./static/css/privacy.min.css --content \"./privacy.html,./static/js/**/*.js\" --minify",
    "build:css:risk": "tailwindcss -i ./src/css/pages/risk.input.css -o ./static/css/risk.min.css --content \"./risk.html,./static/js/**/*.js\" --minify",
    "build:css:terms": "tailwindcss -i ./src/css/pages/terms.input.css -o ./static/css/terms.min.css --content \"./terms.html,./static/js/**/*.js\" --minify",
    "build:css:all": "npm run build:css:cookies && npm run build:css:index && npm run build:css:knowledge && npm run build:css:privacy && npm run build:css:risk && npm run build:css:terms",
    "dev:css": "concurrently \"tailwindcss -i ./src/css/pages/cookies.input.css -o ./static/css/cookies.min.css --content \\\"./cookies.html,./static/js/**/*.js\\\" --watch\" \"tailwindcss -i ./src/css/pages/index.input.css -o ./static/css/index.min.css --content \\\"./index.html,./static/js/**/*.js\\\" --watch\" \"tailwindcss -i ./src/css/pages/knowledge.input.css -o ./static/css/knowledge.min.css --content \\\"./knowledge.html,./static/js/**/*.js\\\" --watch\" \"tailwindcss -i ./src/css/pages/privacy.input.css -o ./static/css/privacy.min.css --content \\\"./privacy.html,./static/js/**/*.js\\\" --watch\" \"tailwindcss -i ./src/css/pages/risk.input.css -o ./static/css/risk.min.css --content \\\"./risk.html,./static/js/**/*.js\\\" --watch\" \"tailwindcss -i ./src/css/pages/terms.input.css -o ./static/css/terms.min.css --content \\\"./terms.html,./static/js/**/*.js\\\" --watch\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "terser": "^5.44.1"
  }
}