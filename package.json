{
  "name": "tsunonton",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tailwindcss -i ./src/input.css -o ./static/css/output.css --watch",
    "build": "tailwindcss -i ./src/input.css -o ./static/css/output.css --minify",
    "build:js": "esbuild static/js/app.js --bundle --minify --outfile=static/js/app.min.js",
    "obfuscate": "esbuild static/js/app.js --bundle --minify --minify-whitespace --minify-identifiers --minify-syntax --tree-shaking=true --drop:console --drop:debugger --legal-comments=none --format=esm --target=es2020 --outfile=static/js/app.min.js",
    "optimize": "npm run build && npm run build:js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "terser": "^5.44.1"
  }
}